{
  "name": "bezotcorp-ai",
  "displayName": "BezotCorp AI",
  "description": "Configurable AI coding assistant for VS Code.",
  "version": "1.6.0",
  "publisher": "bezotcorp",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#0A1025",
    "theme": "dark"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bezot-Corp/vscode-extension-ai.git"
  },
  "homepage": "https://github.com/Bezot-Corp/vscode-extension-ai",
  "bugs": {
    "url": "https://github.com/Bezot-Corp/vscode-extension-ai/issues"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ai",
    "assistant",
    "coding",
    "rust",
    "local",
    "backend",
    "self-hosted"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "BezotCorp AI",
      "properties": {
        "bezotcorpAi.provider": {
          "type": "string",
          "default": "ollama",
          "enum": [
            "ollama",
            "customBackend",
            "bezotcorp"
          ],
          "description": "AI provider used by BezotCorp AI."
        },
        "bezotcorpAi.providerUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "Provider URL. Ollama default is http://127.0.0.1:11434. Custom backend default is usually http://127.0.0.1:4188."
        },
        "bezotcorpAi.model": {
          "type": "string",
          "default": "qwen2.5-coder:7b",
          "description": "Model name used by the selected provider."
        },
        "bezotcorpAi.contextMode": {
          "type": "string",
          "default": "basic",
          "enum": [
            "basic",
            "rich"
          ],
          "description": "Context mode. Basic sends focused context. Rich sends more workspace information."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bezotcorp-ai",
          "title": "BezotCorp AI",
          "icon": "assets/icon.png"
        }
      ]
    },
    "views": {
      "bezotcorp-ai": [
        {
          "id": "bezotcorp-ai-chat",
          "name": "Chat",
          "type": "webview",
          "icon": "assets/icon.png"
        }
      ]
    },
    "commands": [
      {
        "command": "bezotcorp-ai.openChat",
        "title": "BezotCorp AI: Open Chat"
      },
      {
        "command": "bezotcorp-ai.openSettings",
        "title": "BezotCorp AI: Open Settings"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "pnpm compile && vsce package",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^25.9.2",
    "@types/vscode": "^1.120.0",
    "@vscode/vsce": "^3.9.2",
    "semantic-release": "^25.0.3",
    "semantic-release-vsce": "^6.1.5",
    "typescript": "^6.0.3"
  }
}
